{
  "name": "openrelief",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "check": "npm test && npm run evals && npm run policy:validate && npm run lint && npm run test:a11y && npm run test:security && npm run security:audit && npm run docs:check && npm run build && npm run test:e2e",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:a11y": "vitest run apps/web/src/a11y.test.tsx",
    "test:security": "vitest run apps/web/src/security.test.tsx",
    "test:watch": "vitest",
    "lint": "tsc -b --pretty false",
    "evals": "vitest run packages/evals/src",
    "policy:validate": "vitest run packages/policy-packs",
    "docs:check": "vitest run docs/review.test.ts",
    "security:audit": "npm audit --audit-level=critical"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.14",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.4"
  }
}
